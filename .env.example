# Repo-root environment — copy to .env (gitignored)
# Pipeline default: local Ollama only — no keys required for run.py
#
# Hermes / Slack tokens → ~/.hermes/.env
#   See: agentic/hermes/config/hermes.env.example
#
# Scratch while wiring Slack (gitignored):
#   agentic/hermes/slack_deleteme.md

# ── Optional: cloud LLM for pipeline or agentic role overrides ───────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: override Ollama endpoint ───────────────────────────────────────
# OLLAMA_HOST=http://localhost:11434
LOCAL_OLLAMA_HOST=http://localhost:11434
REMOTE_OLLAMA_HOST=http://192.168.1.20:11434
OLLAMA_HOST=${REMOTE_OLLAMA_HOST}

