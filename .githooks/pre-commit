#!/bin/sh
# Three-layer security gate: fast rules → Presidio PII → secret scanner.
# PII findings on .piiignore-listed, non-forbidden paths are deferred to commit-msg,
# where a substantive 'PII-Reviewed:' trailer is required to acknowledge them.
set -eu
cd "$(dirname "$0")/.."
. "$(dirname "$0")/python-venv.sh"
CHECK_SECRETS_PENDING="$(git rev-parse --git-path check-secrets-pending.txt)"
"$PY" scripts/check_secrets.py --staged --emit-review-pending "$CHECK_SECRETS_PENDING"
PII_PENDING="$(git rev-parse --git-path pii-pending.txt)"
"$PY" scripts/audit_pii.py --staged --emit-review-pending "$PII_PENDING"
"$PY" scripts/audit_secrets.py --staged
