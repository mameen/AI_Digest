# Hermes environment — copy to ~/.hermes/.env (or ~/.hermes/profiles/<name>/.env)
# chmod 600 ~/.hermes/.env
#
# Hermes dashboard (Messaging → Slack) uses the same variables.
# Docs: agentic/hermes/slack.md

# ── Required for Slack (Socket Mode) ─────────────────────────────────────────

# Bot User OAuth Token — Slack → OAuth & Permissions (after Install to Workspace)
# Must start with xoxb-
SLACK_BOT_TOKEN=xoxb-PASTE-BOT-TOKEN-HERE

# App-Level Token — Slack → Socket Mode → connections:write
# Must start with xapp- (NOT xoxb-)
SLACK_APP_TOKEN=xapp-PASTE-APP-TOKEN-HERE

# Comma-separated Slack member IDs allowed to talk to the bot (U…)
# Slack → your profile → ⋮ → Copy member ID
SLACK_ALLOWED_USERS=U_PASTE_YOUR_MEMBER_ID

# ── Recommended ──────────────────────────────────────────────────────────────

# Default channel for cron / scheduled notifications (C…)
# Slack → channel details → Channel ID at bottom. Invite bot: /invite @YourBot
SLACK_HOME_CHANNEL=C_PASTE_CHANNEL_ID

# Display label only (optional)
SLACK_HOME_CHANNEL_NAME=digest-bot

# ── Optional ─────────────────────────────────────────────────────────────────

# Restrict bot to specific channels (comma-separated C… / G… IDs)
# SLACK_ALLOWED_CHANNELS=C0123456789,C0987654321

# Dev only — allow any Slack user (do not use in shared workspaces)
# SLACK_ALLOW_ALL_USERS=false

# ── Not used by Hermes Socket Mode (keep in slack_deleteme.md if needed) ─────
# App ID, Client ID, Client Secret, Signing Secret — Slack Basic Information
# for OAuth apps / HTTP verification, not the two token fields above.

# ── Optional cloud LLM keys (if a Hermes profile uses non-Ollama models) ─────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
