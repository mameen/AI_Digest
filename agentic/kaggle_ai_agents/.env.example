# Local development only. Copy this file to .env and fill in real values.
# NEVER commit .env — it is gitignored.
# Rotate any key immediately if it has been shared in chat or logs.

# ── Primary: local Ollama (no cost, no keys required) ────────────────────────
# Default endpoint assumed by the main AI Digest pipeline.
# Override only if Ollama is not on localhost.
OLLAMA_HOST=http://localhost:11434
MODEL_NAME=qwen3.6:35b

# ── Option 1: Gemini API Key (Google AI Studio) ───────────────────────────────
# Required ONLY for agents-cli playground and the ADK codelabs.
# Get from: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_GENAI_USE_ENTERPRISE=FALSE

# ── Option 2: Vertex AI / Google Cloud ────────────────────────────────────────
# Alternative to Option 1 for Google Cloud users.
# Run: gcloud auth application-default login
# Run: gcloud config set project YOUR_PROJECT_ID
# GOOGLE_GENAI_USE_ENTERPRISE=TRUE
# GOOGLE_CLOUD_PROJECT=your_project_id_here
# GOOGLE_CLOUD_LOCATION=us-central1
