# PII audit exemptions — ORIO / AI Digest
# Gitignore-style. Alias file: .ignorepii (same syntax, merged if present).
#
# IMPORTANT: .piiignore is OPT-IN only. Scanners ignore it by default.
# Pass --observe-piiignore to audit_secrets.py to honor these exemptions.
# Pre-commit never passes that flag — commit content
# is always scanned. Forbidden paths (.kb/, .venv/) always alarm if staged.
#
# RULE: paths here MUST be in .gitignore OR be intentional public artifacts.

# ── Local runtime & caches (gitignored) ──────────────────────────────────────
agentic/hermes/.kb/
agentic/hermes/.runtime/
.cache/
.preflight/
llm_pipeline/.cache/
llm_pipeline/.preflight/
.venv/
venv/
__pycache__/

# ── Fixtures & templates ─────────────────────────────────────────────────────
tests/fixtures/
tests/data/
**/*.example.json
**/*.example.yaml
.env.example
.githooks/

# ── Hermes config examples (documented LAN hosts) ───────────────────────────
agentic/hermes/admin/config/hermes_roles.yaml
llm_pipeline/config.yaml

# ── This file itself (contains comments referencing patterns) ────────────────
.piiignore
